{
  "version": 2,
  "routes": [
    {
      "src": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }],
      "continue": true
    },
    {
      "src": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }],
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/admin", "dest": "/index.html" },
    { "src": "/admin/(.*)", "dest": "/index.html" },
    { "src": "/blog/([^/]+)", "dest": "/index.html" },
    { "src": "/fr/blog/([^/]+)", "dest": "/index.html" }
  ]
}
